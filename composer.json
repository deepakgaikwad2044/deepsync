{
    "name": "deepakgaikwad2044/deepsync",
    "description": "Deep Sync Framework is a lightweight, modern PHP framework inspired by Laravel.",
    "type": "project",
    "license": "MIT",

    "authors": [
        {
            "name": "Deepak Gaikwad",
            "email": "deepsyncframework@gmail.com",
            "role": "Founder & Fullstack Web Developer"
        }
    ],

    "keywords": ["php", "framework", "mvc", "deep-sync", "laravel-like"],

    "minimum-stability": "stable",
    "prefer-stable": true,

    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "CLI\\": "cli/",
            "Database\\": "database/"
        },
        "files": ["app/Helper.php"]
    },

    "require": {
        "php": "^8.0",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "cboden/ratchet": "^0.4.4",
        "predis/predis": "^3.4",
        "clue/redis-react": "^2.8",
        "react/event-loop": "^1.6",
        "react/socket": "^1.17",
        "ratchet/pawl": "^0.3",
        "react/dns": "^1.14",
        "guzzlehttp/psr7": "^1.8",
        "react/cache": "^1.2"
    },

    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php -r \"echo '🚀 Deep Sync Framework Installed Successfully!';\""
        ]
    },

    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
